APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
# Local dev: Vite pe 5173. Productie VPS: acelasi domeniu ca APP_URL (https://ocpp.volta.md)
BACKOFFICE_UI_URL=http://127.0.0.1:5173
# Productie: TRUSTED_PROXIES=* (nginx TLS termination)
# TRUSTED_PROXIES=*

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

STRIPE_SECRET=
STRIPE_PUBLIC=
STRIPE_WEBHOOK_SECRET=
# Deep link Stripe (optional, fara app mobila poate ramane gol)
MOBILE_APP_SCHEME=voltaev

OCPP_MODE=gateway
OCPP_HOST=0.0.0.0
OCPP_PORT=9000
# Inlocuieste cu IP-ul LAN al serverului pentru statia fizica (ex: ws://192.168.1.42:9000/ocpp)
OCPP_PUBLIC_URL=ws://127.0.0.1:9000/ocpp
OCPP_HEARTBEAT_INTERVAL=60
OCPP_COMMAND_POLL_INTERVAL_MS=250
OCPP_COMMAND_BATCH_SIZE=6
OCPP_REFRESH_STATUS_SECONDS=3
OCPP_REFRESH_TELEMETRY_SECONDS=5
OCPP_REFRESH_POLL_INTERVAL_MS=200
OCPP_METER_VALUE_SAMPLE_INTERVAL=5
OCPP_START_SYNC_WAIT_MS=1200
OCPP_START_SYNC_WAIT_CONNECTED_MS=400
OCPP_SOFT_RESET_ON_STOP_REJECT=true
OCPP_SOFT_RESET_ON_START_REJECT=true
OCPP_SOFT_RESET_ON_SUSPENDED_EV=true
OCPP_AUTO_RECOVERY_ENABLED=false
OCPP_SUSPENDED_EV_RECOVERY_SECONDS=12
OCPP_REMOTE_START_AFTER_RECOVERY_SECONDS=10

# Prepay wallet (clienti: alimentare + buget inainte de pornire)
PREPAID_WALLET_ENABLED=true

# Expo push — dezactivat (fara app mobila in repo)
EXPO_PUSH_ENABLED=false
OCPP_DIAGNOSTICS_FTP_URL=ftp://diagnostics.local/evolta/

# Conturi locale dupa migrate --seed:
# Backoffice admin: admin@local-ev.test / password123
# App driver demo (card): demo@local-ev.test / password123
# App personal demo: personal@local-ev.test / password123
# Productie: php artisan volta:create-admin --email=... --password=...
